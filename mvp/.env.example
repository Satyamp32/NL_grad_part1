# ─── Spotify Developer App Credentials ───────────────────────────────────────
# Register at: https://developer.spotify.com/dashboard
# Set redirect URI to your deployed URL (e.g., https://your-app.streamlit.app/)
# For local dev use: http://localhost:8502/
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:8502/

# ─── LLM Provider (optional — heuristic fallback used if not set) ─────────────
# Choose "openai" or "anthropic"
LLM_PROVIDER=openai

# If using OpenAI:
OPENAI_API_KEY=your_openai_api_key_here

# If using Anthropic:
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Streamlit Cloud Deployment Notes ────────────────────────────────────────
# On Streamlit Cloud, set the above variables in:
# App Settings → Secrets → Add entries like:
#
# SPOTIFY_CLIENT_ID = "..."
# SPOTIFY_CLIENT_SECRET = "..."
# SPOTIFY_REDIRECT_URI = "https://your-mvp-app.streamlit.app/"
# LLM_PROVIDER = "openai"
# OPENAI_API_KEY = "..."
#
# In your Spotify Developer Dashboard, add your deployed URL as a
# Redirect URI (Settings → Edit → Redirect URIs)
